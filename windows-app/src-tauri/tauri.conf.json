{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "X2 Rental Platform",
  "version": "0.1.0",
  "identifier": "com.x2rental.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "X2 Rental Platform",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "X2 Rental Platform"
  }
}
